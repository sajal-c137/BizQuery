# Groq is the default LLM provider. Swap LLM_BASE_URL + LLM_MODEL for any
# OpenAI-compatible API (OpenAI, Together, OpenRouter, ...).
LLM_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

DATABASE_URL=sqlite:///../database/bizquery.db
CHROMA_DIR=../database/chroma_db
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
